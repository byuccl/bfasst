rule vivado
    command = cd $cwd && {{ vivado_path }} -mode batch -journal $journal -log $log -source $in > /dev/null
    description = vivado $in

{{#in_context}}
rule vivado_ioparse
    command = python {{ bfasst_path }}/bfasst/utils/vivado_ioparse.py <$in >$out
    description = vivado_ioparse <$in >$out
    
{{/in_context}}
